{
  "manifest_version": 3,
  "name": "Rekh Sovereign Bridge",
  "version": "1.2.0",
  "action": {
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs", 
    "notifications", 
    "storage", 
    "scripting", 
    "activeTab"
  ],
  "host_permissions": [
    "https://*.idc.co.za/*",
    "https://*.nef.org.za/*",
    "https://rekh-platform.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.idc.co.za/*", "https://*.nef.org.za/*"],
      "js": ["src/inject.js"]
    }
  ]
}
